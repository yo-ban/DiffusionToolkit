<local:BorderlessWindow x:Class="Diffusion.Toolkit.SystemPromptPresetDialog"
                        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
                        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
                        xmlns:local="clr-namespace:Diffusion.Toolkit"
                        mc:Ignorable="d"
                        WindowStartupLocation="CenterOwner"
                        ShowInTaskbar="False"
                        WindowStyle="ToolWindow"
                        MenuWidth="0"
                        TitleWidth="*"
                        Style="{StaticResource BorderlessWindowStyle}"
                        ResizeMode="CanResize"
                        Title="System Prompt Presets" Height="620" Width="920"
                        MinHeight="460" MinWidth="760">
    <Grid Margin="12,34,12,12">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="36"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="260"/>
            <ColumnDefinition Width="10"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <Grid Grid.Column="0">
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="32"/>
            </Grid.RowDefinitions>
            <ListBox x:Name="PresetsList" DisplayMemberPath="Name" SelectionChanged="PresetsList_OnSelectionChanged"/>
            <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Bottom">
                <Button Width="56" Height="26" Margin="0,0,6,0" Click="AddButton_OnClick" Content="Add"/>
                <Button Width="76" Height="26" Margin="0,0,6,0" Click="DuplicateButton_OnClick" Content="Duplicate"/>
                <Button Width="70" Height="26" Click="RemoveButton_OnClick" Content="Remove"/>
            </StackPanel>
        </Grid>

        <Grid Grid.Column="2">
            <Grid.RowDefinitions>
                <RowDefinition Height="30"/>
                <RowDefinition Height="8"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>
            <TextBox x:Name="NameText" VerticalContentAlignment="Center" TextChanged="NameText_OnTextChanged"/>
            <TextBox x:Name="PromptText" Grid.Row="2" AcceptsReturn="True" TextWrapping="Wrap"
                     VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto"
                     FontFamily="Consolas" FontSize="13" Padding="8" TextChanged="PromptText_OnTextChanged"/>
        </Grid>

        <StackPanel Grid.Row="1" Grid.ColumnSpan="3" Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Bottom">
            <Button Width="90" Height="28" Margin="0,0,8,0" IsDefault="True" Click="OkButton_OnClick" Content="OK"/>
            <Button Width="90" Height="28" IsCancel="True" Click="CancelButton_OnClick" Content="Cancel"/>
        </StackPanel>
    </Grid>
</local:BorderlessWindow>
